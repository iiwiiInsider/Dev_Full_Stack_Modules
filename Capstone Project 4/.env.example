# Copy to .env and fill in values
PORT=3000
SESSION_SECRET=change_me
# Registered app in Azure AD (Entra) - Web platform redirect URI: http://localhost:3000/auth/callback
AZURE_TENANT=common
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:3000/auth/callback
# Optional: limit scopes to read only for safety during dev
AZURE_SCOPES=offline_access Files.Read User.Read Files.Read.All Files.ReadWrite
