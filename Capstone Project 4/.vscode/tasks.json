{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Install dependencies (npm ci fallback to npm i)",
			"type": "shell",
			"command": "bash.exe",
			"args": [
				"-lc",
				"if [ -f package-lock.json ]; then npm ci; else npm install; fi"
			],
			"problemMatcher": [
				"$eslint-stylish"
			],
			"group": "build"
		},
		{
			"label": "Dev server (nodemon)",
			"type": "shell",
			"command": "bash.exe",
			"args": [
				"-lc",
				"npm run dev"
			],
			"isBackground": true,
			"problemMatcher": []
		}
	]
}