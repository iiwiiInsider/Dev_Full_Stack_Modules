<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= typeof title !== 'undefined' && title ? title : 'My Blog' %></title>
  <meta name="color-scheme" content="light dark">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css" />
  <script>document.documentElement.classList.remove('no-js');</script>
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="brand">My Blog</a>
      <form class="searchbar" action="/" method="get">
        <input class="search-input" type="search" name="q" placeholder="Search posts…" value="<%= typeof q !== 'undefined' ? q : '' %>"/>
        <% if (typeof tag !== 'undefined' && tag) { %>
          <input type="hidden" name="tag" value="<%= tag %>">
        <% } %>
        <% if (typeof sort !== 'undefined' && sort) { %>
          <input type="hidden" name="sort" value="<%= sort %>">
        <% } %>
        <button class="btn" type="submit">Search</button>
      </form>
      <nav class="nav">
        <button id="themeToggle" class="btn" type="button" aria-label="Toggle theme">🌓</button>
        <a class="btn primary" href="/posts/new">New Post</a>
      </nav>
    </div>
  </header>
  <main class="container">
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert error"><%= error %></div>
    <% } %>
    <% if (typeof msg !== 'undefined' && msg) { %>
      <div class="toast" data-kind="info"><%= msg %></div>
    <% } %>
    <%- body %>
  </main>
  <footer class="site-footer">
    <div class="container">
      <p>&copy; <%= new Date().getFullYear() %> My Blog. Built with Express & EJS.</p>
    </div>
  </footer>
  <script src="/js/app.js"></script>
</body>
</html>
