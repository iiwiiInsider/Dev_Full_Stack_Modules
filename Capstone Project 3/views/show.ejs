<article class="post reveal">
  <header class="post-header">
    <h1><%= post.title %></h1>
    <p class="muted small">
      <%= readTime(post.body) %> • Updated <time datetime="<%= new Date(post.updatedAt).toISOString() %>"><%= formatDate(post.updatedAt) %></time>
    </p>
    <% if (Array.isArray(post.tags) && post.tags.length) { %>
      <div class="chips">
        <% post.tags.forEach(t => { %>
          <a class="chip" href="/?tag=<%= encodeURIComponent(t) %>"><%= t %></a>
        <% }) %>
      </div>
    <% } %>
  </header>
  <div class="post-body">
    <pre class="prose"><%= post.body %></pre>
  </div>
  <div class="post-actions">
    <a class="btn" href="/">Back</a>
    <a class="btn" href="/posts/<%= post.id %>/edit">Edit</a>
    <button class="btn" type="button" data-copy-link>Copy Link</button>
    <form action="/posts/<%= post.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this post?');">
      <button class="btn danger" type="submit">Delete</button>
    </form>
  </div>
</article>
